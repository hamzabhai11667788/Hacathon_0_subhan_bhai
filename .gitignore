# AI Employee .gitignore

# Environment variables (NEVER commit credentials)
.env
.env.local
.env.*.local

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual environments
venv/
env/
ENV/
.venv

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Logs
*.log
Logs/

# Obsidian vault - only commit structure, not content
AI_Employee_Vault/Needs_Action/*
AI_Employee_Vault/Done/*
AI_Employee_Vault/Plans/*
AI_Employee_Vault/Pending_Approval/*
AI_Employee_Vault/Approved/*
AI_Employee_Vault/Inbox/*
AI_Employee_Vault/Accounting/*
AI_Employee_Vault/Logs/*

# Keep vault structure folders
!AI_Employee_Vault/Needs_Action/.gitkeep
!AI_Employee_Vault/Done/.gitkeep
!AI_Employee_Vault/Plans/.gitkeep
!AI_Employee_Vault/Pending_Approval/.gitkeep
!AI_Employee_Vault/Approved/.gitkeep
!AI_Employee_Vault/Inbox/.gitkeep
!AI_Employee_Vault/Accounting/.gitkeep
!AI_Employee_Vault/Logs/.gitkeep
!AI_Employee_Vault/Briefings/.gitkeep

# Keep core vault files
AI_Employee_Vault/Dashboard.md
AI_Employee_Vault/Company_Handbook.md
AI_Employee_Vault/Business_Goals.md

# Temporary files
tmp/
temp/
*.tmp
